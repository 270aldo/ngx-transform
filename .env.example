# =============================================================================
# Firebase (Client)
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================================
# Firebase (Server)
# =============================================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Gemini
# =============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_HOURLY_LIMIT_USD=20
GEMINI_DAILY_LIMIT_USD=250

# =============================================================================
# OpenAI Realtime (HYBRID conversational classifier)
# =============================================================================
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# =============================================================================
# Rate Limiting (Upstash Redis - REQUERIDO para producción)
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
MAX_SESSIONS_PER_IP_PER_DAY=100
MAX_SESSIONS_PER_EMAIL_PER_DAY=50
ALLOW_RATE_LIMIT_FALLBACK=false

# =============================================================================
# Email (Resend)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL="GENESIS <genesis@ngxvision.app>"
EMAIL_FROM=
FF_EMAIL_SEQUENCE=true

# =============================================================================
# App URLs
# =============================================================================
NEXT_PUBLIC_APP_URL=https://ngxvision.app
NEXT_PUBLIC_BASE_URL=
NEXT_PUBLIC_BOOKING_URL=
# NECESITA_DATO_DEL_OWNER: email legal/de soporte publicado en Privacy/Terms y footers.
NEXT_PUBLIC_SUPPORT_EMAIL=
# NECESITA_DATO_DEL_OWNER: razon social/persona responsable legal.
NEXT_PUBLIC_LEGAL_RESPONSIBLE_NAME=
# NECESITA_DATO_DEL_OWNER: domicilio legal del responsable.
NEXT_PUBLIC_LEGAL_RESPONSIBLE_ADDRESS=
NEXT_PUBLIC_WAITLIST_URL=
VERCEL_URL=

# =============================================================================
# Cierre HYBRID (Calendly + WhatsApp + Video del fundador)
# =============================================================================
# NECESITA_DATO_DEL_OWNER: URL final de agenda. Si queda vacío, no se muestra CTA de Calendly.
NEXT_PUBLIC_CALENDLY_URL=
# NECESITA_DATO_DEL_OWNER: teléfono WhatsApp en formato internacional, sin espacios preferentemente.
NEXT_PUBLIC_WHATSAPP_NUMBER=
# NECESITA_DATO_DEL_OWNER: copy comercial vigente de cohorte/cupo.
# IMPORTANTE: COHORT_SPOTS solo con valores REALES. Vacíos = la UI usa el fallback
# honesto y NO muestra contador. Nunca poner números inventados (riesgo PROFECO). Ver fix-05/#7.
NEXT_PUBLIC_COHORT_LABEL=
NEXT_PUBLIC_COHORT_SPOTS_TOTAL=
NEXT_PUBLIC_COHORT_SPOTS_LEFT=

# Video del fundador (embed flexible: YouTube, Vimeo, MP4 propio)
# Soporta URLs como:
#   https://www.youtube.com/embed/VIDEO_ID
#   https://player.vimeo.com/video/VIDEO_ID
#   https://storage.googleapis.com/.../founder.mp4
NEXT_PUBLIC_HYBRID_VIDEO_URL=
NEXT_PUBLIC_HYBRID_VIDEO_POSTER=
NEXT_PUBLIC_HYBRID_VIDEO_DURATION_SEC=240

# =============================================================================
# Mercado Pago Checkout Pro (NGX HYBRID)
# =============================================================================
# Obtener en: https://www.mercadopago.com.mx/developers/panel/credentials
MP_ACCESS_TOKEN=
# Reservado para integraciones client-side futuras; el Checkout Pro actual usa redirect server-side.
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Pricing NGX HYBRID en MXN (3 SKUs)
# NECESITA_DATO_DEL_OWNER: define al menos un precio > 0 para activar compra directa.
NEXT_PUBLIC_HYBRID_PRICE_MONTHLY=
NEXT_PUBLIC_HYBRID_PRICE_QUARTERLY=
NEXT_PUBLIC_HYBRID_PRICE_ANNUAL=
NEXT_PUBLIC_HYBRID_CURRENCY=MXN

# Descripciones cortas mostradas en cada card (opcionales — defaults en código)
NEXT_PUBLIC_HYBRID_LABEL_MONTHLY=Acceso mensual
NEXT_PUBLIC_HYBRID_LABEL_QUARTERLY=12 semanas (cohorte completa)
NEXT_PUBLIC_HYBRID_LABEL_ANNUAL=Programa anual

# IDs/SKUs internos para tracking
HYBRID_SKU_MONTHLY=hybrid_monthly_v1
HYBRID_SKU_QUARTERLY=hybrid_quarterly_v1
HYBRID_SKU_ANNUAL=hybrid_annual_v1

# =============================================================================
# Feature Flags
# =============================================================================
FF_TELEMETRY_ENABLED=true
FF_DELETE_TOKEN_REQUIRED=true
FF_NB_PRO=true
FF_IDENTITY_CHAIN=true
FF_QUALITY_GATES=true
FF_CINEMATIC_AUTOPLAY=true
FF_COMPARE_SLIDER=true
FF_LETTER_FROM_FUTURE=true
FF_DRAMATIC_REVEAL=true
FF_OG_SPLIT_SCREEN=true
FF_SHARE_UNLOCK=false
FF_SHARE_TO_UNLOCK=false
FF_REFERRAL_TRACKING=true
FF_PLAN_7_DIAS=false
FF_SOCIAL_COUNTER=true
FF_AGENT_BRIDGE_CTA=false
FF_EXPOSE_ORIGINAL=true
NEXT_PUBLIC_FF_RESULTS_2=true
NEXT_PUBLIC_DEMO_MODE=

# v12 Comercial Exit Flow
# Cuando true: usa HybridOfferV2 (diagnóstico HYBRID + brief + video + WhatsApp)
NEXT_PUBLIC_FF_HYBRID_OFFER_V2=true
# Cuando true: muestra checkout directo de Mercado Pago dentro de HybridOfferV2.
# Default false: Transform funciona como lead magnet hacia diagnóstico HYBRID.
NEXT_PUBLIC_FF_HYBRID_DIRECT_CHECKOUT=false
# Cuando true: muestra agente conversacional por voz/texto en resultados HYBRID.
NEXT_PUBLIC_FF_HYBRID_VOICE_AGENT=false
NEXT_PUBLIC_HYBRID_VOICE_AGENT_PROVIDER=openai
# GENESIS text chat (Fase 2) — segundo canal conversacional sobre la misma KB.
NEXT_PUBLIC_FF_HYBRID_TEXT_CHAT=true        # default on; "false" para desactivar
GENESIS_CHAT_MODEL=gemini-2.5-flash         # cerebro del chat de texto (barato/rápido)
GENESIS_CHAT_TIMEOUT_MS=30000               # acota el arranque del stream de Gemini
# Cuando true: redirige /s/[shareId]/demo y /plan a /s/[shareId] (flujo colapsado)
NEXT_PUBLIC_FF_COLLAPSE_FUNNEL=true

# =============================================================================
# Limits / runtime
# =============================================================================
MAX_ANALYSIS_RETRIES=3
MAX_IMAGE_GENERATION_RETRIES=2

# Timeouts opcionales para llamadas a Gemini (ms). Tienen defaults en código.
# Acotan cuelgues del proveedor para que el job no se congele (fix-16).
GEMINI_ANALYSIS_TIMEOUT_MS=30000
GEMINI_IMAGE_TIMEOUT_MS=90000
PLAN_GENERATION_TIMEOUT_MS=30000
MAX_UPLOAD_BYTES=10485760
SESSION_TTL_DAYS=30
SHARE_UNLOCK_DELAY_SECONDS=5
SOCIAL_COUNTER_SEED_TOTAL=8547
SOCIAL_COUNTER_SEED_WEEKLY=2341

# =============================================================================
# N8N Webhooks
# =============================================================================
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_URL=

# =============================================================================
# Security / Cron
# =============================================================================
CRON_API_KEY=
UNSUBSCRIBE_SECRET=              # HMAC secret for unsubscribe links; use a separate random value in production
AI_WORKER_TOKEN=
ENABLE_AI_GENERATION=true
AI_FLAGS_FIRESTORE_PATH=config/aiFlags/global
AI_FLAG_CACHE_TTL_MS=30000

# =============================================================================
# Sentry (P1 Observability)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# =============================================================================
# Edge Config (optional)
# =============================================================================
EDGE_CONFIG_ID=
EDGE_CONFIG_URL=
EDGE_CONFIG_TOKEN=
VERCEL_EDGE_CONFIG_ID=
VERCEL_EDGE_CONFIG_TOKEN=

# =============================================================================
# Build/runtime
# =============================================================================
# No configures NODE_ENV manualmente en Vercel; Vercel lo define por entorno.
NODE_ENV=development
PLAN_GENERATION_MODEL=gemini-flash-latest

# =============================================================================
# Local/Test-only toggles
# =============================================================================
# No usar en produccion salvo incidente controlado.
DISABLE_RATE_LIMITS=false
RATE_LIMIT_MODE=
ENFORCE_RATE_LIMITS_IN_DEV=false
ENFORCE_RATE_LIMITS_ON_LOCALHOST=false

# Smoke/auth tests
TEST_BASE_URL=
TEST_SHARE_ID=
TEST_CRON_API_KEY=
TEST_OWNER_ID_TOKEN=
TEST_USER_A_TOKEN=
TEST_USER_B_TOKEN=
TEST_USER_A_SESSION_ID=
REQUIRE_SMOKE_ENV=false
