# Template for the local P1/P2 validation gate (Firebase Emulator Suite).
# Copy to .env.emulator.local (gitignored) and generate a throwaway key:
#
#   cp .env.emulator.example .env.emulator.local
#   KEY=$(openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 2>/dev/null \
#         | awk '{printf "%s\\n", $0}')
#   # paste $KEY into FIREBASE_PRIVATE_KEY below
#
# Everything here is FAKE and emulator-only. The FIRESTORE/AUTH emulator hosts
# force firebase-admin to talk to localhost — it can never reach a real project,
# even if a real .env.local is also present.

# --- Firebase Admin (fake; required so firebaseAdmin.ts cert() parses) ---
FIREBASE_PROJECT_ID=demo-ngx
FIREBASE_CLIENT_EMAIL=seed@demo-ngx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nGENERATE_A_THROWAWAY_KEY_SEE_HEADER\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-ngx.appspot.com

# --- Firebase client (placeholders; emulator accepts any) ---
NEXT_PUBLIC_FIREBASE_API_KEY=demo-emulator-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-ngx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-ngx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=0
NEXT_PUBLIC_FIREBASE_APP_ID=demo-emulator-app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Emulator routing (the safety net) ---
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
STORAGE_EMULATOR_HOST=http://127.0.0.1:9199
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# --- Gate behavior ---
DISABLE_RATE_LIMITS=true
FF_DELETE_TOKEN_REQUIRED=true
NEXT_PUBLIC_FF_HYBRID_DIRECT_CHECKOUT=false
NEXT_PUBLIC_FF_HYBRID_VOICE_AGENT=true
FF_HYBRID_VOICE_AGENT=true

# --- Misc (fake; never called by the gate) ---
CRON_API_KEY=emulator-cron-key
AI_WORKER_TOKEN=emulator-worker-token
GEMINI_API_KEY=emulator-fake-gemini
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
